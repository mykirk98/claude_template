# clang-tidy config for C++ sources — see rules/cpp-code-style.md
# Only checks that map to a rule in the guide are enabled. Rules clang-tidy
# cannot encode stay prose-only in the guide:
#   - Hungarian type prefixes (p / str / n) after m_
#   - boolean names starting with is / has / can / should
#   - enum class over plain enum
Checks: >
  -*,
  cppcoreguidelines-pro-type-cstyle-cast,
  cppcoreguidelines-no-malloc,
  cppcoreguidelines-owning-memory,
  cppcoreguidelines-special-member-functions,
  modernize-use-override,
  performance-noexcept-move-constructor,
  readability-function-size,
  readability-identifier-naming
HeaderFilterRegex: '.*'
CheckOptions:
  readability-function-size.LineThreshold: '40'
  readability-function-size.ParameterThreshold: '5'
  readability-identifier-naming.FunctionCase: camelBack
  readability-identifier-naming.MethodCase: camelBack
  readability-identifier-naming.VariableCase: camelBack
  readability-identifier-naming.ParameterCase: camelBack
  readability-identifier-naming.ClassCase: CamelCase
  readability-identifier-naming.StructCase: CamelCase
  readability-identifier-naming.EnumCase: CamelCase
  readability-identifier-naming.TypeAliasCase: CamelCase
  readability-identifier-naming.TypedefCase: CamelCase
  readability-identifier-naming.TemplateParameterCase: CamelCase
  readability-identifier-naming.ConstexprVariableCase: UPPER_CASE
  readability-identifier-naming.GlobalConstantCase: UPPER_CASE
  readability-identifier-naming.MacroDefinitionCase: UPPER_CASE
  readability-identifier-naming.PrivateMemberPrefix: 'm_'
  readability-identifier-naming.PrivateMemberCase: camelBack
  readability-identifier-naming.ProtectedMemberPrefix: 'm_'
  readability-identifier-naming.ProtectedMemberCase: camelBack
